<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
  <!-- Dark blue background circle -->
  <circle cx="100" cy="100" r="100" fill="#1e3a5f"/>

  <!-- White lotus/flower petals -->
  <g fill="none" stroke="white" stroke-width="7" stroke-linecap="round" stroke-linejoin="round">
    <!-- Top petal (center) -->
    <path d="M100,50 L110,85 L100,115 L90,85 Z"/>

    <!-- Upper right petal -->
    <path d="M145,70 Q160,65 170,75 Q160,85 145,90 Q150,75 140,80"/>

    <!-- Lower right petal -->
    <path d="M160,130 Q175,125 180,140 Q165,150 150,145 Q160,135 155,140"/>

    <!-- Lower left petal -->
    <path d="M40,130 Q25,125 20,140 Q35,150 50,145 Q40,135 45,140"/>

    <!-- Upper left petal -->
    <path d="M55,70 Q40,65 30,75 Q40,85 55,90 Q50,75 60,80"/>
  </g>
</svg>